# Copy file ini jadi .env dan isi dengan credentials Supabase kamu.
# Dapatkan dari Supabase Dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional server-side AI untuk analisa rekonsiliasi.
# Isi di Vercel Environment Variables / .env local server, jangan pakai prefix VITE_.
# Format ini OpenAI-compatible, bisa dipakai OpenAI atau Kimi/Moonshot.
RECONCILIATION_AI_PROVIDER=openai-compatible
RECONCILIATION_AI_BASE_URL=https://api.openai.com/v1
RECONCILIATION_AI_API_KEY=your-server-side-ai-key
RECONCILIATION_AI_MODEL=your-model-name

# Alternatif alias kalau pakai Kimi/Moonshot:
# KIMI_API_KEY=your-kimi-key
# KIMI_MODEL=kimi-k2.6
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# ── SECURITY NOTE ──
# JANGAN pernah menyertakan SERVICE_ROLE_KEY atau secret key lainnya di frontend.
# Service Role Key hanya boleh digunakan di server-side atau local seeding script.
